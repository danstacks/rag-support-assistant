# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CONTEXT_WINDOW=8192  # Max context tokens (8K)

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
# Collection name defaults to the value in domain.yaml; override here if needed
# CHROMA_COLLECTION_NAME=sonic_docs

# Domain Configuration
# Path to the YAML file that defines scrape presets, prompts, and branding.
# Default: searches for domain.yaml in project root.
# DOMAIN_CONFIG_PATH=./domain.yaml

# Embedding Model (HuggingFace)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Documentation Directory
DOCS_DIRECTORY=./data/docs

# Credential Encryption (IMPORTANT for production)
# Generate a secure key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a machine-specific key is derived automatically (works for single-server deployments)
# CREDENTIAL_ENCRYPTION_KEY=your-secure-key-here
